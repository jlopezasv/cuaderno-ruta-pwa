# ─── Desarrollo local (cuaderno-pwa) ─────────────────────────────────────────
# Copiar a .env.local (gitignored). NUNCA commitear claves reales.
#
# Obligatorias: mismo proyecto Supabase en cliente (Vite) y API (vercel dev).

# ── Cliente (Vite) — obligatorias ──
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── Serverless (vercel dev / api/*) — obligatorias ──
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Opcionales (funciones / integraciones) ──
ANTHROPIC_API_KEY=
BREVO_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
