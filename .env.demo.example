# ─── CUADERNO DE RUTA — ENTORNO DEMO (plantilla) ─────────────────────────────
#
# Copiar valores al proyecto Vercel DEMO (nunca al de producción).
# Proyecto Supabase DEMO independiente (ref distinto de glyexutcypmhkndvmcxd).
#
# Checklist: docs/DEMO_ENVIRONMENT.md
# ─────────────────────────────────────────────────────────────────────────────

# ── Identidad de entorno (obligatorio en Vercel demo) ──
VITE_APP_ENV=demo
APP_ENV=demo
VITE_DEMO_SUPABASE_PROJECT_REF=YOUR_DEMO_PROJECT_REF
DEMO_SUPABASE_PROJECT_REF=YOUR_DEMO_PROJECT_REF

# NUNCA en demo:
# VITE_ALLOW_PROD_SUPABASE=1
# ALLOW_PROD_SUPABASE=1

# ── Supabase DEMO — cliente (Vite) ──
VITE_SUPABASE_URL=https://YOUR_DEMO_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=demo_anon_key_only

# ── Supabase DEMO — servidor (api/*) ──
SUPABASE_URL=https://YOUR_DEMO_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=demo_anon_key_only
SUPABASE_SERVICE_ROLE_KEY=demo_service_role_only

# Registro libre: desactivado en app + Dashboard Auth
# VITE_ALLOW_PUBLIC_SIGNUP=1
# ALLOW_PUBLIC_SIGNUP=1

# ── CORS (dominio demo) ──
ALLOWED_ORIGIN=https://demo.tu-dominio.vercel.app

# ── Admin demo (UIDs del seed, no producción) ──
ADMIN_PANEL_USER_IDS=a0000000-0000-4000-8000-000000000010
# ALLOW_PURGE_TEST_COMPANY=1
# VITE_ENABLE_PURGE_TEST_COMPANY=1

# ── Integraciones: vacías o proyecto demo separado ──
# ANTHROPIC_API_KEY=          # opcional; clave de prueba
# BREVO_API_KEY=                # vacío → sin emails reales
# STRIPE_SECRET_KEY=            # NUNCA claves live
# STRIPE_WEBHOOK_SECRET=
# VITE_FIREBASE_*               # proyecto FCM demo o vacío
# VAPID_*=
