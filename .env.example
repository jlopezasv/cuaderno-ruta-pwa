# ─── CUADERNO DE RUTA — Variables de entorno ─────────────────
#
# 1. Copia este archivo y renómbralo a .env.local (para desarrollo local)
# 2. En Vercel: Settings → Environment Variables → añade cada variable
#
# NUNCA subas el .env.local a GitHub (ya está en .gitignore)
# ─────────────────────────────────────────────────────────────

# API KEY de Anthropic — OBLIGATORIA para el asistente IA
# Consíguela en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXX

# Tu dominio de producción (para CORS)
# Ejemplo: https://cuaderno-ruta.vercel.app
# Déjalo vacío en desarrollo
ALLOWED_ORIGIN=https://tu-app.vercel.app

# Entorno (Vercel lo pone automáticamente)
# NODE_ENV=production
