# ─── CUADERNO DE RUTA — Variables de entorno ─────────────────
#
# 1. Copia este archivo y renómbralo a .env.local (para desarrollo local)
# 2. En Vercel: Settings → Environment Variables → añade cada variable
#
# NUNCA subas el .env.local a GitHub (ya está en .gitignore)
# ─────────────────────────────────────────────────────────────

# Supabase — archivado de usuarios desde /api/admin (PATCH profiles.is_archived)
# La service role key solo en servidor (Vercel); no la expongas al cliente.
SUPABASE_URL=https://glyexutcypmhkndvmcxd.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Opcional: cadena Postgres del proyecto (Settings → Database) para npm run validate:operativa con psql / supabase db query
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# UUIDs separados por coma que pueden llamar a archive_user (por defecto incluye el admin del panel en app)
ADMIN_PANEL_USER_IDS=
# Purga total empresa de PRUEBA (action purge_test_company). Requiere VERCEL_ENV distinto de production + flag explícito.
ALLOW_PURGE_TEST_COMPANY=
# Opcional: UUID del único usuario que puede purgar (por defecto = primer id de ADMIN_PANEL_USER_IDS)
PRIMARY_PURGE_ADMIN_UID=
# Opcional: frase exacta que debe enviar el cliente en confirm_text (default PURGO_EMPRESA_PRUEBA)
PURGE_TEST_COMPANY_CONFIRM=

# Cliente (Vite): mostrar botón "Purgar empresa de prueba" en panel admin en builds staging/preview
# VITE_ENABLE_PURGE_TEST_COMPANY=1

# API KEY de Anthropic — OBLIGATORIA para el asistente IA
# Consíguela en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXX

# Tu dominio de producción (para CORS)
# Ejemplo: https://cuaderno-ruta.vercel.app
# Déjalo vacío en desarrollo
ALLOWED_ORIGIN=https://tu-app.vercel.app

# Entorno (Vercel lo pone automáticamente)
# NODE_ENV=production
