# ─── CUADERNO DE RUTA — Variables de entorno ─────────────────
#
# 1. Desarrollo: cp .env.local.example .env.local
# 2. Vercel: Settings → Environment Variables (Production ≠ Preview)
#
# NUNCA subas .env.local a Git (está en .gitignore)
# ─────────────────────────────────────────────────────────────

# ── Supabase — cliente (Vite, obligatorias) ──
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=
# Solo en Vercel Production (proyecto REAL): VITE_ALLOW_PROD_SUPABASE=1

# ── Supabase — servidor (api/* en Vercel / vercel dev) ──
# Deben apuntar al MISMO proyecto que VITE_* del mismo entorno.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Solo en Vercel Production (proyecto REAL): ALLOW_PROD_SUPABASE=1

# Opcional: Postgres directo (scripts compare / psql)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[PASSWORD]@...

# Admin panel (/api/admin)
ADMIN_PANEL_USER_IDS=
ALLOW_PURGE_TEST_COMPANY=
PRIMARY_PURGE_ADMIN_UID=
PURGE_TEST_COMPANY_CONFIRM=

# Cliente (Vite): botón purga en staging
# VITE_ENABLE_PURGE_TEST_COMPANY=1

# Anthropic — /api/cmr, /api/chat
ANTHROPIC_API_KEY=

# CORS API (opcional)
ALLOWED_ORIGIN=

# Stripe, push, email — ver docs/PUSH_FCM_SETUP.md
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# BREVO_API_KEY=
